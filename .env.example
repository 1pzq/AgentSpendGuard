# Runtime mode for local demos: mock or real.
SPENDGUARD_MODE=mock

# Base Sepolia runtime configuration.
TARGET_CHAIN_ID=84532
TARGET_CHAIN_NAME=base-sepolia
BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
BASE_SEPOLIA_WS_URL=wss://base-sepolia.infura.io/ws/v3/YOUR_INFURA_PROJECT_ID

# Base Sepolia USDC.
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# AI provider configuration. DeepSeek can be real while permission/1Shot stay demo-only.
AI_PROVIDER=deepseek
AI_MODE=mock
DEEPSEEK_MODE=mock
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Legacy Venice configuration, kept for provider swapping.
VENICE_MODE=mock
VENICE_API_KEY=
VENICE_API_BASE=https://api.venice.ai/api/v1
VENICE_MODEL=

# x402 payment configuration.
X402_PAY_TO=0xe61109ccCbf5a9b15F805e58e9A0ec286a46d0Be
X402_NETWORK=eip155:84532
# For ERC-7710 paid PoC on Base Sepolia, use MetaMask's x402 facilitator.
X402_FACILITATOR_URL=https://tx-sentinel-base-sepolia.api.cx.metamask.io/platform/v2/x402
# Optional explicit ERC-7710 facilitator/redeemer signer addresses. The app
# defaults these for MetaMask's Base Sepolia facilitator.
X402_ERC7710_FACILITATOR_ADDRESSES=
# Optional project-local proxy for server-side x402 facilitator fetches.
X402_PROXY_URL=

# Real ERC-7710 x402 paid PoC. Default off; enabling spends Base Sepolia USDC.
ERC7710_PAID_POC_ENABLED=false
ERC7710_PAID_POC_PRICE_ATOMIC=10000
# Main policy per-call price. Defaults to ERC7710_PAID_POC_PRICE_ATOMIC so
# Run Agent and the ERC-7710 paid path stay aligned.
SPENDGUARD_PRICE_PER_CALL_ATOMIC=10000
# Optional self-settlement path for the ERC-7710 paid PoC. The private key must
# be funded with Base Sepolia ETH and must never be exposed to the browser.
ERC7710_SELF_SETTLE_ENABLED=false
FACILITATOR_ADDRESS=
FACILITATOR_PRIVATE_KEY=
ERC7710_SELF_SETTLE_RECEIPT_POLL_MS=2000
ERC7710_SELF_SETTLE_RECEIPT_TIMEOUT_MS=120000

# 1Shot relayer configuration.
ONESHOT_MODE=mock
ONESHOT_BASE_URL=
ONESHOT_API_KEY=
ONESHOT_WEBHOOK_SECRET=

# Local app URL used by future integrations.
NEXT_PUBLIC_APP_URL=http://localhost:3000
